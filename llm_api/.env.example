# ============================================================
# LLM API (OpenAI-compatible endpoint)
# ============================================================
# For local vLLM deployment:
#   LLM_BASE_URL=http://host.docker.internal:8000/v1
#   LLM_API_KEY=EMPTY   (vLLM accepts any value, "EMPTY" is convention)
#   LLM_MODEL=google/gemma-3-27b-it
#
# For Google's Gemini/Gemma API (OpenAI-compatible endpoint):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_API_KEY=your_google_ai_studio_api_key_here
#   LLM_MODEL=gemma-3-27b-it
# ============================================================
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=replace_me_with_your_key
LLM_MODEL=gemma-3-27b-it

# ============================================================
# Speech-to-Text API (OpenAI-compatible Whisper endpoint)
# Can be the same server or different (vLLM, OpenAI, local Whisper, etc.)
# ============================================================
STT_BASE_URL=https://api.openai.com/v1
STT_API_KEY=replace_me_with_your_key
STT_MODEL=whisper-1

# ============================================================
# App config
# ============================================================
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=info

# Max upload size in MB
MAX_UPLOAD_MB=25
